---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
---
<Base title="Page Not Found">
  <section class="nf">
    <div class="container-x nf-inner">
      <div class="nf-code">404</div>
      <h1>Page not found</h1>
      <p>Sorry, we couldn't find the page you're looking for. It might have been moved or doesn't exist.</p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary">Go home <Icon name="arrow" size={15} /></a>
        <a href="/contact" class="btn btn-ghost">Contact support</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { min-height: 62vh; display: grid; place-items: center; text-align: center; }
  .nf-inner { max-width: 34rem; }
  .nf-code { font-family: var(--font-mono); font-size: clamp(4rem, 14vw, 8rem); font-weight: 600; color: var(--color-blue-100); line-height: 1; letter-spacing: -0.04em; }
  .nf h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); margin-top: 0.5rem; }
  .nf p { color: var(--color-ink-muted); margin: 1rem 0 2rem; }
  .nf-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
</style>
