---
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---
<div class:list={["news", compact && "news--compact"]}>
  <span class="eyebrow eyebrow--plain">Newsletter</span>
  <h3>Stay updated</h3>
  <p>Subscribe for the latest news, releases, and open-neuroscience updates.</p>
  <form name="newsletter" method="POST" data-netlify="true" action="/success" class="news-form" netlify-honeypot="bot-field">
    <input type="hidden" name="form-name" value="newsletter" />
    <p class="hidden-field"><label>Don't fill this out: <input name="bot-field" /></label></p>
    <input type="email" name="email" required placeholder="you@lab.edu" aria-label="Email address" />
    <button type="submit" class="btn btn-primary">Subscribe</button>
  </form>
</div>

<style>
  .news h3 { font-size: 1.5rem; margin: 0.8rem 0 0.5rem; }
  .news p { color: var(--color-ink-muted); margin-bottom: 1.2rem; }
  .news-form { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .news-form input[type="email"] {
    flex: 1 1 14rem; padding: 0.7rem 0.9rem; border: 1px solid var(--color-line);
    border-radius: 0.55rem; font-family: var(--font-sans); font-size: 0.95rem; background: var(--color-surface);
  }
  .news-form input[type="email"]:focus { outline: none; border-color: var(--color-blue); box-shadow: 0 0 0 3px var(--color-blue-50); }
  .hidden-field { display: none; }
  .news--compact { text-align: left; }
</style>
