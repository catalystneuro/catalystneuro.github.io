---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import Icon from "../components/Icon.astro";
import Newsletter from "../components/Newsletter.astro";
import { SITE } from "../consts";

const methods = [
  { icon: "mail", title: "Email us", body: SITE.email, note: "We typically respond within 1–2 business days.", href: `mailto:${SITE.email}` },
  { icon: "calendar", title: "Schedule a consultation", body: "Book a free 30-minute call to discuss your project.", cta: { label: "Book a call", href: "/consultation" } },
  { icon: "map", title: "Mailing address", body: SITE.address.join(", ") },
];
---
<Base title="Contact" description="Get in touch with CatalystNeuro to discuss NWB conversions, data standardization, and open-source software for your neuroscience lab.">
  <PageHeader
    eyebrow="Get in touch"
    title="Contact us"
    subtitle="We'd love to hear from you. Get in touch with our team."
  />

  <section class="section">
    <div class="container-x contact-grid">
      <div class="contact-methods">
        {methods.map((m) => (
          <div class="card contact-card">
            <div class="contact-icon"><Icon name={m.icon} size={20} /></div>
            <div>
              <h3>{m.title}</h3>
              {m.href ? <a href={m.href} class="contact-link">{m.body}</a> : <p class="contact-body">{m.body}</p>}
              {m.note && <p class="contact-note">{m.note}</p>}
              {m.cta && <a href={m.cta.href} class="btn btn-ghost btn-sm contact-cta">{m.cta.label} <Icon name="arrow" size={14} /></a>}
            </div>
          </div>
        ))}
        <div class="card contact-card">
          <div class="contact-icon"><Icon name="github" size={20} /></div>
          <div>
            <h3>Connect with us</h3>
            <div class="contact-socials">
              <a href={SITE.github} target="_blank" rel="noopener" class="btn btn-ghost btn-sm"><Icon name="github" size={15} /> GitHub</a>
              <a href={SITE.linkedin} target="_blank" rel="noopener" class="btn btn-ghost btn-sm"><Icon name="linkedin" size={15} /> LinkedIn</a>
            </div>
          </div>
        </div>
      </div>

      <aside class="card contact-news"><Newsletter /></aside>
    </div>
  </section>
</Base>

<style>
  .contact-grid { display: grid; gap: 2rem; grid-template-columns: 1fr; align-items: start; }
  @media (min-width: 880px) { .contact-grid { grid-template-columns: 1.4fr 1fr; } }
  .contact-methods { display: flex; flex-direction: column; gap: 1rem; }
  .contact-card { padding: 1.5rem; display: flex; gap: 1.1rem; align-items: flex-start; }
  .contact-icon { flex-shrink: 0; width: 2.8rem; height: 2.8rem; border-radius: 0.65rem; background: var(--color-blue-50); color: var(--color-blue); display: grid; place-items: center; }
  .contact-card h3 { font-size: 1.12rem; margin-bottom: 0.3rem; }
  .contact-link { color: var(--color-blue); font-weight: 500; }
  .contact-body { color: var(--color-navy); }
  .contact-note { color: var(--color-ink-muted); font-size: 0.88rem; margin-top: 0.3rem; }
  .contact-cta { margin-top: 0.9rem; }
  .contact-socials { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.3rem; }
  .contact-news { padding: 2rem; }
</style>
