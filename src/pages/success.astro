---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
---
<Base title="Thank You" description="Thanks for subscribing to the CatalystNeuro newsletter.">
  <section class="success">
    <div class="container-x success-inner">
      <div class="success-mark"><Icon name="check" size={30} /></div>
      <h1>Thank you for subscribing!</h1>
      <p>We'll keep you updated with our latest news and updates.</p>
      <a href="/" class="btn btn-primary">Return home <Icon name="arrow" size={15} /></a>
    </div>
  </section>
</Base>

<style>
  .success { min-height: 60vh; display: grid; place-items: center; text-align: center; }
  .success-inner { max-width: 32rem; }
  .success-mark { width: 4.5rem; height: 4.5rem; border-radius: 50%; background: color-mix(in srgb, #16a34a 14%, white); color: #15803d; display: grid; place-items: center; margin: 0 auto 1.5rem; }
  .success h1 { font-size: clamp(1.8rem, 4vw, 2.5rem); }
  .success p { color: var(--color-ink-muted); margin: 1rem 0 2rem; font-size: 1.1rem; }
</style>
