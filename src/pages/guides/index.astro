---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import Icon from "../../components/Icon.astro";

const guides = (await getCollection("software")).filter((s) => s.data.type === "guide");
---
<Base title="Documentation & Guides" description="Step-by-step guides and reference documentation for working with CatalystNeuro tools and the Neurodata Without Borders (NWB) ecosystem.">
  <PageHeader
    eyebrow="Documentation"
    title="Guides"
    subtitle="Step-by-step guides and reference documentation for working with CatalystNeuro and the NWB ecosystem."
  />

  <section class="section">
    <div class="container-x">
      <div class="gd-grid">
        {guides.map((g) => (
          <a href={`/guides/${g.id}`} class="card card-hover gd-card">
            <div class="gd-icon"><Icon name="book" size={20} /></div>
            <div class="gd-body">
              <h3>{g.data.name}</h3>
              <p>{g.data.description}</p>
              <span class="gd-link">View guide <Icon name="arrow" size={15} /></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .gd-grid { display: grid; gap: 1.3rem; grid-template-columns: 1fr; }
  @media (min-width: 780px) { .gd-grid { grid-template-columns: repeat(2, 1fr); } }
  .gd-card { padding: 1.8rem; display: flex; gap: 1.2rem; align-items: flex-start; }
  .gd-icon { flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 0.7rem; background: var(--color-blue-50); color: var(--color-blue); display: grid; place-items: center; }
  .gd-body h3 { font-size: 1.25rem; }
  .gd-body p { color: var(--color-ink-muted); margin: 0.5rem 0 1rem; font-size: 0.95rem; }
  .gd-link { color: var(--color-blue); font-weight: 500; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.35rem; }
  .gd-card:hover .gd-link { gap: 0.55rem; }
</style>
