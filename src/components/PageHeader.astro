---
interface Props { eyebrow?: string; title: string; subtitle?: string; count?: string }
const { eyebrow, title, subtitle, count } = Astro.props;
---
<section class="page-head">
  <div class="container-x">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <div class="page-head-row">
      <h1>{title}</h1>
      {count && <span class="page-head-count">{count}</span>}
    </div>
    {subtitle && <p class="page-head-sub">{subtitle}</p>}
  </div>
  <div class="page-head-grid" aria-hidden="true"></div>
</section>

<style>
  .page-head { position: relative; padding: 3.5rem 0 2.5rem; border-bottom: 1px solid var(--color-line); overflow: hidden; }
  .page-head .eyebrow { margin-bottom: 1.1rem; }
  .page-head-row { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .page-head h1 { font-size: clamp(2.1rem, 5vw, 3.1rem); }
  .page-head-count { font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-blue); padding: 0.2rem 0.6rem; border: 1px solid var(--color-line); border-radius: 0.4rem; }
  .page-head-sub { margin-top: 1rem; max-width: 44rem; font-size: 1.1rem; color: var(--color-ink-muted); line-height: 1.6; }
  .page-head-grid {
    position: absolute; inset: 0; z-index: -1; opacity: 0.5;
    background-image: linear-gradient(var(--color-line-soft) 1px, transparent 1px), linear-gradient(90deg, var(--color-line-soft) 1px, transparent 1px);
    background-size: 44px 44px;
    -webkit-mask-image: radial-gradient(circle at 85% 0%, black, transparent 60%);
    mask-image: radial-gradient(circle at 85% 0%, black, transparent 60%);
  }
</style>
