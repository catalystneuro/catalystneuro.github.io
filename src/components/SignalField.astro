---
/*
  Signature element: a stack of electrophysiology "channels" rendered as SVG
  traces, the way a lab would view multichannel neural recordings. One channel
  is highlighted in the electric accent and carries a slow travelling pulse.
  This grounds the hero in the subject's own visual language instead of stock art.
*/
interface Props { channels?: number; class?: string }
const { channels = 7, class: cls = "" } = Astro.props;

const W = 720;
const rowH = 46;
const H = channels * rowH;

// Deterministic pseudo-random so the SVG is stable across builds.
function mulberry(seed: number) {
  return () => {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

function trace(row: number, seed: number, spiky: boolean) {
  const rnd = mulberry(seed);
  const midY = row * rowH + rowH / 2;
  const pts: string[] = [];
  const step = 6;
  for (let x = 0; x <= W; x += step) {
    let y = midY + (rnd() - 0.5) * 4; // baseline noise
    // occasional spikes
    if (spiky && rnd() > 0.9) y = midY - (10 + rnd() * 12);
    if (spiky && rnd() > 0.95) y = midY + (8 + rnd() * 8);
    pts.push(`${x},${y.toFixed(1)}`);
  }
  return "M" + pts.join(" L");
}

const rows = Array.from({ length: channels }, (_, i) => ({
  d: trace(i, i * 97 + 13, i !== 2),
  highlight: i === 2,
}));
---
<div class={`signal-field ${cls}`} aria-hidden="true">
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" width="100%" height="100%">
    <defs>
      <linearGradient id="sig-fade" x1="0" x2="1">
        <stop offset="0" stop-color="var(--color-signal)" stop-opacity="0"></stop>
        <stop offset="0.5" stop-color="var(--color-signal)" stop-opacity="1"></stop>
        <stop offset="1" stop-color="var(--color-signal)" stop-opacity="0"></stop>
      </linearGradient>
    </defs>
    {rows.map((r, i) => (
      <>
        <line x1="0" x2={W} y1={i * rowH + rowH / 2} y2={i * rowH + rowH / 2}
              stroke="rgba(255,255,255,0.06)" stroke-width="1" />
        <path d={r.d} fill="none"
              stroke={r.highlight ? "url(#sig-fade)" : "rgba(127,224,240,0.28)"}
              stroke-width={r.highlight ? 2 : 1.25}
              class={r.highlight ? "trace trace--live" : "trace"} />
      </>
    ))}
  </svg>
</div>

<style>
  .signal-field { width: 100%; height: 100%; overflow: hidden; }
  .trace--live { filter: drop-shadow(0 0 6px rgba(34,199,230,0.6)); }
  .trace--live {
    stroke-dasharray: 140 620;
    animation: sweep 6s linear infinite;
  }
  @keyframes sweep { to { stroke-dashoffset: -760; } }
  @media (prefers-reduced-motion: reduce) { .trace--live { animation: none; stroke-dasharray: none; } }
</style>
