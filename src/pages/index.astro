---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import SignalField from "../components/SignalField.astro";
import Newsletter from "../components/Newsletter.astro";
import {
  HERO, STAT_LABELS, WHY, SERVICES, PARTNERS, INSTITUTIONS, FEATURED, TESTIMONIALS,
} from "../data/site-content";

const posts = (await getCollection("blog"))
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1))
  .slice(0, 3);

// Count the portfolio rather than hardcoding the numbers, so the stats can
// never drift from the content. "Multi-institution Collaboration" is a
// placeholder rather than a real institution, so it is excluded.
const conversions = await getCollection("conversions");
const fundedProjects = await getCollection("fundedProjects");
const uniqueInstitutions = new Set(
  conversions.map((c) => c.data.institution).filter((i) => i !== "Multi-institution Collaboration")
);
const STATS = [
  { value: String(conversions.length), label: STAT_LABELS.labs },
  { value: String(fundedProjects.length), label: STAT_LABELS.projects },
  { value: String(uniqueInstitutions.size), label: STAT_LABELS.institutions },
];

const capIcons = ["cloud", "users", "chart", "code"];
const serviceIcons = ["database", "code", "spark"];
---
<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"><SignalField channels={9} /></div>
    <div class="container-x hero-inner">
      <span class="eyebrow hero-eyebrow">{HERO.eyebrow}</span>
      <h1 class="hero-title">
        {HERO.titleTop}<br /><span class="hero-accent">{HERO.titleAccent}</span>
      </h1>
      <p class="hero-body">{HERO.body}</p>
      <div class="hero-cta">
        <a href={HERO.primary.href} class="btn btn-primary">{HERO.primary.label} <Icon name="arrow" size={16} /></a>
        <a href={HERO.secondary.href} class="btn btn-ondark">{HERO.secondary.label}</a>
      </div>

      <div class="pipeline">
        {HERO.pipeline.map((p, i) => (
          <>
            <div class="pipe-step">
              <span class="pipe-num">{p.step}</span>
              <div>
                <div class="pipe-title">{p.title}</div>
                <div class="pipe-copy">{p.copy}</div>
              </div>
            </div>
            {i < HERO.pipeline.length - 1 && <div class="pipe-arrow" aria-hidden="true"><Icon name="arrow" size={16} /></div>}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container-x stats-grid">
      {STATS.map((s) => (
        <div class="stat">
          <div class="stat-value">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- WHY -->
  <section class="section">
    <div class="container-x">
      <div class="why-head">
        <span class="eyebrow">{WHY.eyebrow}</span>
        <h2 class="section-title">{WHY.title}</h2>
        <p class="section-lead">{WHY.body}</p>
      </div>
      <div class="why-grid">
        {WHY.cards.map((c, i) => (
          <div class="card why-card">
            <span class="why-index">0{i + 1}</span>
            <h3>{c.title}</h3>
            <p>{c.copy}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section--alt">
    <div class="container-x">
      <span class="eyebrow">{SERVICES.eyebrow}</span>
      <h2 class="section-title">{SERVICES.title}</h2>
      <p class="section-lead">{SERVICES.body}</p>

      <div class="svc-grid">
        {SERVICES.items.map((s, i) => (
          <div class="card card-hover svc-card">
            <div class="svc-icon"><Icon name={serviceIcons[i]} size={22} /></div>
            <h3>{s.title}</h3>
            <p class="svc-copy">{s.copy}</p>
            <ul class="svc-features">
              {s.features.map((f) => (
                <li><Icon name="check" size={15} /> <span>{f}</span></li>
              ))}
            </ul>
            <a href={s.link.href} class="svc-link">{s.link.label} <Icon name="arrow" size={15} /></a>
          </div>
        ))}
      </div>

      <div class="caps">
        {SERVICES.capabilities.map((c, i) => (
          <div class="cap"><Icon name={capIcons[i]} size={18} /> <span>{c}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS + INSTITUTIONS -->
  <section class="section">
    <div class="container-x">
      <div class="logos-head">
        <span class="eyebrow">{PARTNERS.title}</span>
      </div>
      <div class="logo-row">
        {PARTNERS.logos.map((l) => (
          <img src={l.src} alt={l.name} title={l.name} class="logo-img" loading="lazy" />
        ))}
      </div>

      <div class="inst-head">
        <h2 class="section-title">Working with labs at {uniqueInstitutions.size} institutions</h2>
      </div>
      <div class="inst-grid" id="inst-grid">
        {INSTITUTIONS.map((l, i) => (
          <div class="inst-cell" style={l.scale ? `--logo-scale:${l.scale}` : undefined} data-extra={i >= 18 ? "true" : "false"} hidden={i >= 18}>
            <img src={l.src} alt={l.name} title={l.name} loading="lazy" />
          </div>
        ))}
      </div>
      <button class="btn btn-ghost btn-sm inst-toggle" id="inst-toggle">Show all institutions <Icon name="chevron" size={15} /></button>
    </div>
  </section>

  <!-- FEATURED IN -->
  <section class="section section--alt">
    <div class="container-x">
      <span class="eyebrow">{FEATURED.title}</span>
      <div class="feat-grid">
        {FEATURED.articles.map((a) => (
          <a href={a.url} target="_blank" rel="noopener" class="card card-hover feat-card">
            <span class="feat-pub">{a.publication}</span>
            <h3>{a.title}</h3>
            <p>{a.description}</p>
            <div class="feat-foot"><span>By {a.author}</span><Icon name="arrow-up-right" size={16} /></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section">
    <div class="container-x">
      {TESTIMONIALS.map((t) => (
        <figure class="quote">
          <div class="quote-mark" aria-hidden="true">"</div>
          <blockquote>{t.quote}</blockquote>
          <figcaption>
            <span class="quote-name">{t.name}</span>
            <span class="quote-role">{t.title}, {t.institution}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- LATEST POSTS -->
  <section class="section section--alt">
    <div class="container-x">
      <div class="posts-head">
        <div>
          <span class="eyebrow">Latest</span>
          <h2 class="section-title">Releases, writing, and events</h2>
        </div>
        <a href="/blog" class="btn btn-ghost btn-sm">View all posts <Icon name="arrow" size={15} /></a>
      </div>
      <div class="posts-grid">
        {posts.map((p) => (
          <a href={`/blog/${p.id}`} class="card card-hover post-card">
            {p.data.image && <div class="post-img"><img src={p.data.image} alt={p.data.title} loading="lazy" /></div>}
            <div class="post-body">
              <span class="post-date">{p.data.date}{p.data.readTime ? ` · ${p.data.readTime}` : ""}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA + NEWSLETTER -->
  <section class="section">
    <div class="container-x cta-band">
      <div class="cta-copy">
        <h2 class="section-title">Have a dataset or tool that needs a home?</h2>
        <p class="section-lead">Book a free 30-minute call and we'll map out the fastest path to standardized, shareable, reusable data.</p>
        <a href="/consultation" class="btn btn-primary">Request a consultation <Icon name="arrow" size={16} /></a>
      </div>
      <div class="card cta-news"><Newsletter /></div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero { position: relative; background: radial-gradient(120% 120% at 80% -10%, #1b2358 0%, var(--color-ink) 55%); color: #fff; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; opacity: 0.55; -webkit-mask-image: linear-gradient(90deg, transparent, black 40%); mask-image: linear-gradient(90deg, transparent, black 40%); }
  .hero-inner { position: relative; padding: 5rem 1.5rem 0; }
  .hero-eyebrow { color: var(--color-signal-soft); margin-bottom: 1.5rem; }
  .hero-title { color: #fff; font-size: clamp(2.5rem, 6.5vw, 4.6rem); line-height: 1.02; max-width: 16ch; }
  .hero-accent { color: var(--color-signal); }
  .hero-body { margin-top: 1.5rem; max-width: 34rem; font-size: 1.15rem; line-height: 1.6; color: rgba(255,255,255,0.78); }
  .hero-cta { margin-top: 2rem; display: flex; gap: 0.8rem; flex-wrap: wrap; }

  .pipeline { margin-top: 4rem; display: flex; align-items: stretch; gap: 0.5rem; flex-wrap: wrap; border-top: 1px solid rgba(255,255,255,0.12); padding: 1.6rem 0 2.2rem; }
  .pipe-step { display: flex; gap: 0.9rem; align-items: flex-start; flex: 1 1 12rem; }
  .pipe-num { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-signal); border: 1px solid rgba(34,199,230,0.35); border-radius: 0.35rem; padding: 0.15rem 0.4rem; }
  .pipe-title { font-weight: 600; color: #fff; font-family: var(--font-display); }
  .pipe-copy { font-size: 0.9rem; color: rgba(255,255,255,0.6); margin-top: 0.15rem; }
  .pipe-arrow { color: rgba(255,255,255,0.3); align-self: center; display: none; }
  @media (min-width: 780px) { .pipe-arrow { display: block; } }

  /* STATS */
  .stats { background: var(--color-navy); color: #fff; }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .stat { padding: 2.2rem 1rem; text-align: center; border-right: 1px solid rgba(255,255,255,0.1); }
  .stat:last-child { border-right: 0; }
  .stat-value { font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3rem); font-weight: 600; color: #fff; }
  .stat-label { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-top: 0.3rem; }

  /* Section scaffolding */
  .section { padding: 5rem 0; }
  .section--alt { background: var(--color-surface); border-block: 1px solid var(--color-line); }
  .section-title { font-size: clamp(1.8rem, 3.5vw, 2.4rem); margin-top: 0.8rem; max-width: 20ch; }
  .section-lead { margin-top: 1rem; max-width: 42rem; color: var(--color-ink-muted); font-size: 1.08rem; line-height: 1.6; }

  /* WHY */
  .why-grid { margin-top: 3rem; display: grid; gap: 1.2rem; grid-template-columns: 1fr; }
  @media (min-width: 780px) { .why-grid { grid-template-columns: repeat(3, 1fr); } }
  .why-card { padding: 1.8rem; position: relative; }
  .why-index { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-blue); }
  .why-card h3 { font-size: 1.2rem; margin: 0.8rem 0 0.5rem; }
  .why-card p { color: var(--color-ink-muted); font-size: 0.96rem; }

  /* SERVICES */
  .svc-grid { margin-top: 2.5rem; display: grid; gap: 1.2rem; grid-template-columns: 1fr; }
  @media (min-width: 860px) { .svc-grid { grid-template-columns: repeat(3, 1fr); } }
  .svc-card { padding: 1.8rem; display: flex; flex-direction: column; }
  .svc-icon { width: 3rem; height: 3rem; border-radius: 0.7rem; background: var(--color-blue-50); color: var(--color-blue); display: grid; place-items: center; margin-bottom: 1.1rem; }
  .svc-card h3 { font-size: 1.3rem; }
  .svc-copy { color: var(--color-ink-muted); margin: 0.6rem 0 1.1rem; }
  .svc-features { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; margin-bottom: 1.4rem; }
  .svc-features li { display: flex; gap: 0.55rem; font-size: 0.92rem; color: #3a445e; }
  .svc-features svg { color: var(--color-blue); flex-shrink: 0; margin-top: 0.15rem; }
  .svc-link { margin-top: auto; color: var(--color-blue); font-weight: 500; font-size: 0.92rem; display: inline-flex; align-items: center; gap: 0.35rem; }
  .svc-link:hover { gap: 0.55rem; }
  .caps { margin-top: 1.2rem; display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .cap { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.55rem 0.9rem; border: 1px solid var(--color-line); border-radius: 0.5rem; font-size: 0.88rem; color: var(--color-navy); background: var(--color-paper); }
  .cap svg { color: var(--color-blue); }

  /* LOGOS */
  .logos-head { text-align: center; }
  .logo-row { margin-top: 1.6rem; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 2.5rem 3rem; }
  .logo-img { height: 42px; width: auto; max-width: 130px; object-fit: contain; filter: grayscale(1); opacity: 0.6; transition: all 0.2s; }
  .logo-img:hover { filter: grayscale(0); opacity: 1; }
  .inst-head { margin-top: 4.5rem; text-align: center; }
  .inst-head .section-title { margin-inline: auto; }
  /* The hairline grid is drawn by each cell outlining itself into the 1px gap,
     rather than by a coloured container showing through. That way the empty
     slots in a part-filled last row show the section background instead of a
     block of --color-line. */
  .inst-grid { margin-top: 2rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; border-radius: 0.7rem; }
  @media (min-width: 640px) { .inst-grid { grid-template-columns: repeat(6, 1fr); } }
  .inst-cell { background: var(--color-surface); outline: 1px solid var(--color-line); aspect-ratio: 3/2; display: grid; place-items: center; padding: 1rem; }
  .inst-cell img { max-height: calc(42px * var(--logo-scale, 1)); max-width: 100%; object-fit: contain; filter: grayscale(1); opacity: 0.65; transition: all 0.2s; }
  .inst-cell img:hover { filter: grayscale(0); opacity: 1; }
  .inst-toggle { margin: 1.6rem auto 0; display: flex; }

  /* FEATURED */
  .feat-grid { margin-top: 2rem; display: grid; gap: 1.2rem; grid-template-columns: 1fr; }
  @media (min-width: 720px) { .feat-grid { grid-template-columns: repeat(2, 1fr); } }
  .feat-card { padding: 1.8rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .feat-pub { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-blue); }
  .feat-card h3 { font-size: 1.3rem; }
  .feat-card p { color: var(--color-ink-muted); }
  .feat-foot { margin-top: auto; padding-top: 0.8rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; color: var(--color-ink-soft); }
  .feat-card:hover .feat-foot svg { color: var(--color-blue); }

  /* QUOTE */
  .quote { max-width: 46rem; margin-inline: auto; text-align: center; position: relative; }
  .quote-mark { font-family: var(--font-display); font-size: 5rem; line-height: 0.5; color: var(--color-blue-100); height: 2.5rem; }
  .quote blockquote { font-family: var(--font-display); font-size: clamp(1.3rem, 3vw, 1.7rem); line-height: 1.4; color: var(--color-navy); font-weight: 500; letter-spacing: -0.01em; }
  .quote figcaption { margin-top: 1.6rem; display: flex; flex-direction: column; gap: 0.15rem; }
  .quote-name { font-weight: 600; color: var(--color-navy); }
  .quote-role { font-size: 0.9rem; color: var(--color-ink-muted); }

  /* POSTS */
  .posts-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.2rem; }
  .posts-grid { display: grid; gap: 1.2rem; grid-template-columns: 1fr; }
  @media (min-width: 780px) { .posts-grid { grid-template-columns: repeat(3, 1fr); } }
  .post-card { overflow: hidden; display: flex; flex-direction: column; }
  .post-img { aspect-ratio: 16/9; overflow: hidden; background: var(--color-paper); }
  .post-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s var(--ease-out-expo); }
  .post-card:hover .post-img img { transform: scale(1.04); }
  .post-body { padding: 1.3rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .post-date { font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-ink-soft); text-transform: uppercase; letter-spacing: 0.05em; }
  .post-body h3 { font-size: 1.15rem; line-height: 1.25; }
  .post-body p { font-size: 0.92rem; color: var(--color-ink-muted); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  /* CTA */
  .cta-band { display: grid; gap: 2.5rem; grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 860px) { .cta-band { grid-template-columns: 1.2fr 1fr; } }
  .cta-news { padding: 2rem; }
</style>

<script>
  const toggle = document.getElementById("inst-toggle");
  const grid = document.getElementById("inst-grid");
  let open = false;
  toggle?.addEventListener("click", () => {
    open = !open;
    grid?.querySelectorAll<HTMLElement>('[data-extra="true"]').forEach((el) => {
      if (open) el.removeAttribute("hidden"); else el.setAttribute("hidden", "");
    });
    toggle.firstChild!.textContent = open ? "Show fewer institutions " : "Show all institutions ";
  });
</script>
