---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../consts";

export async function getStaticPaths() {
  const openings = await getCollection("openings");
  return openings.map((o) => ({ params: { id: o.data.id }, props: { o } }));
}
const { o } = Astro.props;
const d = o.data;
const mailto = `mailto:${SITE.email}?subject=${encodeURIComponent("Application: " + d.title)}`;
---
<Base title={d.title} description={d.description}>
  <article>
    {d.image && <div class="job-hero"><img src={d.image} alt={d.title} /><div class="job-hero-fade"></div></div>}
    <div class="container-x job-wrap">
      <a href="/openings" class="post-back"><Icon name="arrow" size={15} class="flip" /> All positions</a>
      <h1>{d.title}</h1>
      <p class="job-meta">{d.type} · {d.location}</p>
      <p class="job-desc">{d.description}</p>

      {d.responsibilities && d.responsibilities.length > 0 && (
        <section class="job-section">
          <h2>Responsibilities</h2>
          <ul class="job-list">{d.responsibilities.map((r) => <li><Icon name="check" size={16} /> <span>{r}</span></li>)}</ul>
        </section>
      )}
      {d.requirements && d.requirements.length > 0 && (
        <section class="job-section">
          <h2>Requirements</h2>
          <ul class="job-list">{d.requirements.map((r) => <li><Icon name="check" size={16} /> <span>{r}</span></li>)}</ul>
        </section>
      )}

      <a href={mailto} class="btn btn-primary job-apply"><Icon name="mail" size={16} /> Apply now</a>
    </div>
  </article>
</Base>

<style>
  .job-hero { position: relative; height: 18rem; overflow: hidden; background: var(--color-ink); }
  .job-hero img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
  .job-hero-fade { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, var(--color-paper)); }
  .job-wrap { max-width: 44rem; margin-inline: auto; padding-top: 2.5rem; }
  .post-back { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-blue); margin-bottom: 1.4rem; }
  .post-back :global(.flip) { transform: rotate(180deg); }
  .job-wrap h1 { font-size: clamp(2rem, 4vw, 2.7rem); }
  .job-meta { font-family: var(--font-mono); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-blue); margin: 0.8rem 0 1.5rem; }
  .job-desc { font-size: 1.1rem; color: var(--color-ink-muted); line-height: 1.6; }
  .job-section { margin-top: 2.5rem; }
  .job-section h2 { font-size: 1.4rem; margin-bottom: 1rem; }
  .job-list { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .job-list li { display: flex; gap: 0.6rem; color: #3a445e; }
  .job-list svg { color: var(--color-blue); flex-shrink: 0; margin-top: 0.15rem; }
  .job-apply { margin-top: 2.5rem; }
</style>
